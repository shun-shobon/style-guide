{
	"name": "style-guide",
	"type": "module",
	"description": "shun-shobon's engineering style guide monorepo",
	"repository": {
		"type": "git",
		"url": "https://github.com/shun-shobon/style-guide.git"
	},
	"homepage": "https://github.com/shun-shobon/style-guide#readme",
	"author": "NISHIZAWA Shuntaro <me@s2n.tech> (https://s2n.tech/)",
	"license": "MIT",
	"private": true,
	"packageManager": "pnpm@10.32.0",
	"scripts": {
		"build": "pnpm -r --filter './packages/*' run build",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"release": "pnpm build && changeset publish",
		"typecheck": "pnpm -r --filter './packages/*' run typecheck",
		"typegen": "pnpm --filter @shun-shobon/eslint-config run typegen",
		"version-package": "changeset version && pnpm format"
	},
	"devDependencies": {
		"@changesets/cli": "2.30.0",
		"@shun-shobon/eslint-config": "workspace:*",
		"@shun-shobon/prettier-config": "workspace:*",
		"@types/node": "24.12.0",
		"eslint": "10.0.3",
		"prettier": "3.8.1",
		"tsdown": "0.21.1",
		"typescript": "5.9.3"
	}
}
