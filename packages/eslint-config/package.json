{
	"name": "@shun-shobon/eslint-config",
	"version": "1.1.0",
	"type": "module",
	"description": "shun-shobon's ESLint config",
	"repository": {
		"type": "git",
		"url": "https://github.com/shun-shobon/style-guide.git"
	},
	"homepage": "https://github.com/shun-shobon/style-guide/tree/main/packages/eslint-config#readme",
	"author": "NISHIZAWA Shuntaro <me@s2n.tech> (https://s2n.tech/)",
	"license": "MIT",
	"exports": {
		".": {
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"CHANGELOG.md",
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"typegen": "node --experimental-transform-types scripts/typegen.ts"
	},
	"peerDependencies": {
		"eslint": "^9.0.0 || ^10.0.0"
	},
	"dependencies": {
		"@eslint/core": "1.1.1",
		"@eslint/js": "10.0.1",
		"@next/eslint-plugin-next": "16.1.6",
		"@typescript-eslint/parser": "8.57.0",
		"astro-eslint-parser": "1.3.0",
		"eslint-config-flat-gitignore": "2.2.1",
		"eslint-import-resolver-typescript": "4.4.4",
		"eslint-plugin-astro": "1.6.0",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-n": "17.24.0",
		"eslint-plugin-qwik": "1.19.1",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-simple-import-sort": "12.1.1",
		"eslint-plugin-storybook": "10.2.17",
		"eslint-plugin-unicorn": "63.0.0",
		"globals": "17.4.0",
		"local-pkg": "1.1.2",
		"typescript-eslint": "8.57.0"
	},
	"devDependencies": {
		"eslint-typegen": "2.3.1"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"sideEffects": false
}
